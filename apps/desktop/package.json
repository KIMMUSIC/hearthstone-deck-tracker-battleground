{
  "name": "@bg-tracker/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Hearthstone Battlegrounds Tracker - Desktop Overlay",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder --dir",
    "package": "tsc -p tsconfig.node.json && vite build && electron-builder",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint src/ electron/",
    "clean": "rm -rf dist dist-electron"
  },
  "dependencies": {
    "@bg-tracker/shared-types": "workspace:*",
    "@bg-tracker/shared-constants": "workspace:*",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.0",
    "koffi": "^2.9.0",
    "zustand": "^5.0.0",
    "framer-motion": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^3.0.0"
  }
}
